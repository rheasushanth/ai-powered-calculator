# AI-Powered Calculator Backend Environment Variables

# Server Configuration
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# LLM Configuration
# Set LLM_PROVIDER to either 'claude' or 'openai'
LLM_PROVIDER=claude
LLM_API_KEY=your_api_key_here
LLM_MODEL=claude-3.5-sonnet-20241022
LLM_TIMEOUT=10000

# Currency API (coming in v1.1)
CURRENCY_API_ENDPOINT=https://api.exchangerate-api.com/v4/latest
CURRENCY_CACHE_DURATION=3600

# Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=100
AI_RATE_LIMIT_MAX=200

# Logging
LOG_LEVEL=info
